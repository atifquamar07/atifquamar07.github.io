<div class="visitor-map-card" aria-label="visitor map">
  <div class="visitor-map-widget">
    <script
      type="text/javascript"
      id="mapmyvisitors"
      src="https://mapmyvisitors.com/map.js?d=jXbSyu9yHiqrIMG4S_wgh10OvbCo0cw11tLcV38Qv30&cl=ffffff&w=a&t=tt"
    ></script>
    <script>
      (function () {
        function updateVisitorMapWidget() {
          var mapLink = document.querySelector('.visitor-map-widget #mapmyvisitors-widget');
          if (mapLink) {
            mapLink.setAttribute('target', '_blank');
            mapLink.setAttribute('rel', 'external nofollow noopener');
          }

          var counter = document.querySelector('.visitor-map-widget .mapmyvisitors-visitors');
          if (!counter || counter.querySelector('.visitor-map-pageviews')) return;

          var match = counter.textContent.trim().match(/^([\d,]+)\s+Total Pageviews$/i);
          if (!match) return;

          counter.innerHTML = '<span class="visitor-map-pageviews">' + match[1] + ' Pageviews</span>';
        }

        var observer = new MutationObserver(updateVisitorMapWidget);
        observer.observe(document.body, { childList: true, subtree: true, characterData: true });
        updateVisitorMapWidget();
      })();
    </script>
  </div>
</div>
